---
import '../styles/global.css';

const {
	title = 'UruWhy Discord Oficial',
	description = 'Visualiza y organiza usuarios de Discord por departamento de Uruguay.'
} = Astro.props;

const BACKEND_URL =
	import.meta.env.PUBLIC_API_URL ??
	import.meta.env.PUBLIC_API_BASE_URL ??
	import.meta.env.URL_BACKEND ??
	'http://localhost:4000';
const DISCORD_AUTH_URL = `${BACKEND_URL}/auth/discord`;
---

<!doctype html>
<html lang="es-UY">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="font-sans antialiased">
		<header class="session-bar" data-session-bar>
			<div class="session-copy">
				<span class="session-dot" aria-hidden="true"></span>
				<span data-session-status>Verificando sesion...</span>
			</div>

			<a class="session-action" href={DISCORD_AUTH_URL} data-session-action hidden>
				Conectar Discord
			</a>

			<div class="session-user" data-session-user hidden>
				<img class="session-avatar" data-session-avatar alt="Avatar de Discord" hidden />
				<div class="session-user-copy">
					<strong data-session-username></strong>
					<span>Sesion activa con Discord</span>
				</div>
			</div>

			<button class="session-logout" type="button" data-session-logout hidden>
				Cerrar sesion
			</button>
		</header>

		<slot />

		<script is:inline define:vars={{ BACKEND_URL }}>
			const status = document.querySelector('[data-session-status]');
			const action = document.querySelector('[data-session-action]');
			const user = document.querySelector('[data-session-user]');
			const avatar = document.querySelector('[data-session-avatar]');
			const username = document.querySelector('[data-session-username]');
			const logout = document.querySelector('[data-session-logout]');
			const bar = document.querySelector('[data-session-bar]');
			const SESSION_STORAGE_KEY = 'penca_session_fallback';

			const updateDiscordAuthUrlWithState = () => {
				if (!action) {
					return;
				}

				const returnPath = `${window.location.pathname}${window.location.search}` || '/';
				const currentOrigin = window.location.origin;
				const returnUrl = new URL(returnPath, currentOrigin).toString();
				const url = new URL(`${BACKEND_URL}/auth/discord`);

				// OAuth2 standard: backend can read state and redirect to this exact frontend URL.
				url.searchParams.set('state', returnUrl);
				// Optional alias to support transitional backends before full state handling.
				url.searchParams.set('redirectTo', returnUrl);

				action.href = url.toString();
			};

			const persistSessionFromHash = () => {
				const rawHash = window.location.hash.replace(/^#/, '');

				if (!rawHash) {
					return;
				}

				const hashParams = new URLSearchParams(rawHash);
				const encodedSession = hashParams.get('penca_session');

				if (!encodedSession) {
					return;
				}

				try {
					window.localStorage.setItem(SESSION_STORAGE_KEY, encodedSession);
				} catch {
					// Ignore storage issues and continue with cookie-only auth.
				}

				hashParams.delete('penca_session');
				const nextHash = hashParams.toString();
				const nextUrl = `${window.location.pathname}${window.location.search}${nextHash ? `#${nextHash}` : ''}`;
				window.history.replaceState(null, '', nextUrl);
			};

			const getAuthHeaders = () => {
				try {
					const encodedSession = window.localStorage.getItem(SESSION_STORAGE_KEY);

					if (encodedSession) {
						return {
							'x-penca-session': encodedSession
						};
					}
				} catch {
					// Ignore storage issues and continue with cookie-only auth.
				}

				return {};
			};

			if (status && action && user && avatar && username && logout && bar) {
				updateDiscordAuthUrlWithState();
				persistSessionFromHash();

				const setLoggedOut = () => {
					bar.dataset.state = 'logged-out';
					status.textContent = 'No has iniciado sesion con Discord';
					action.hidden = false;
					user.hidden = true;
					logout.hidden = true;
				};

				const setLoggedIn = (session) => {
					bar.dataset.state = 'logged-in';
					status.textContent = 'Conectado con Discord';
					action.hidden = true;
					user.hidden = false;
					logout.hidden = false;
					username.textContent = session.globalName || session.username;

					if (session.avatar) {
						const avatarUrl = `https://cdn.discordapp.com/avatars/${session.discordId}/${session.avatar}.png?size=64`;
						avatar.src = avatarUrl;
						avatar.hidden = false;
					} else {
						avatar.hidden = true;
					}
				};

				fetch(`${BACKEND_URL}/auth/me`, {
					headers: getAuthHeaders(),
					credentials: 'include'
				})
					.then((response) => (response.ok ? response.json() : Promise.reject(new Error('No session'))))
					.then((data) => {
						const session = data?.user;

						if (session?.discordId && session?.username) {
							setLoggedIn(session);
							return;
						}

						try {
							window.localStorage.removeItem(SESSION_STORAGE_KEY);
						} catch {
							// Ignore storage cleanup issues.
						}

						setLoggedOut();
					})
					.catch(() => {
						setLoggedOut();
						status.textContent = 'No se pudo verificar la sesion (puedes iniciar sesion igual)';
					});

				logout.addEventListener('click', () => {
					fetch(`${BACKEND_URL}/auth/logout`, {
						headers: getAuthHeaders(),
						credentials: 'include'
					})
						.then((response) => {
							if (!response.ok) {
								throw new Error('Logout failed');
							}

							try {
								window.localStorage.removeItem(SESSION_STORAGE_KEY);
							} catch {
								// Ignore storage cleanup issues.
							}

							window.location.reload();
						})
						.catch(() => {
							status.textContent = 'No se pudo cerrar la sesion';
						});
				});
			}
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		padding-top: 86px;
	}

	.session-bar {
		position: fixed;
		inset: 14px 14px auto;
		z-index: 30;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		padding: 12px 16px;
		border: 1px solid rgba(148, 163, 184, 0.35);
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(14px);
		box-shadow: 0 16px 36px rgba(14, 116, 144, 0.15);
	}

	.session-copy {
		display: flex;
		align-items: center;
		gap: 10px;
		min-width: 0;
		color: #0f172a;
		font-size: 14px;
		font-weight: 500;
	}

	.session-dot {
		width: 10px;
		height: 10px;
		border-radius: 999px;
		background: #f59e0b;
		box-shadow: 0 0 0 6px rgba(245, 158, 11, 0.18);
		flex: 0 0 auto;
	}

	.session-bar[data-state='logged-in'] .session-dot {
		background: #16a34a;
		box-shadow: 0 0 0 6px rgba(22, 163, 74, 0.18);
	}

	.session-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 9px 14px;
		border-radius: 999px;
		background: linear-gradient(135deg, #5865f2, #4752c4);
		color: white;
		text-decoration: none;
		font-size: 13px;
		font-weight: 600;
		white-space: nowrap;
		box-shadow: 0 10px 20px rgba(88, 101, 242, 0.28);
	}

	.session-action[hidden] {
		display: none !important;
	}

	.session-user {
		display: flex;
		align-items: center;
		gap: 12px;
		min-width: 0;
	}

	.session-avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		border: 1px solid rgba(148, 163, 184, 0.3);
		object-fit: cover;
		flex: 0 0 auto;
	}

	.session-user-copy {
		display: grid;
		gap: 2px;
		min-width: 0;
	}

	.session-user-copy strong {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.session-user-copy span {
		color: #475569;
		font-size: 12px;
	}

	.session-logout {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 9px 13px;
		border-radius: 999px;
		border: 1px solid rgba(148, 163, 184, 0.45);
		background: rgba(241, 245, 249, 0.85);
		color: #0f172a;
		font-size: 13px;
		font-weight: 500;
		cursor: pointer;
		transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
	}

	.session-logout:hover {
		transform: translateY(-1px);
		border-color: rgba(239, 68, 68, 0.35);
		background: rgba(254, 226, 226, 0.92);
	}

	.session-logout:focus-visible {
		outline: 2px solid rgba(14, 165, 233, 0.5);
		outline-offset: 2px;
	}

	.session-logout[hidden] {
		display: none !important;
	}

	.session-bar[data-state='logged-in'] .session-action {
		display: none;
	}

	.session-bar[data-state='logged-out'] .session-user {
		display: none;
	}

	@media (max-width: 768px) {
		body {
			padding-top: 116px;
		}

		.session-bar {
			inset: 10px 10px auto;
			flex-wrap: wrap;
			justify-content: center;
			text-align: center;
		}

		.session-copy {
			width: 100%;
			justify-content: center;
		}

		.session-user {
			width: 100%;
			justify-content: center;
		}
	}
</style>
